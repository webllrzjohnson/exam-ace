DATABASE_URL="postgresql://user:password@localhost:5432/cad_exam"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-min-32-chars"
AUTH_TRUST_HOST=true
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"

# Password reset & email verification (dev: logs link to console; prod: set Resend or SMTP)
# For production, set to your domain: https://citizen.maplehub.cloud
RESET_PASSWORD_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Resend (recommended for production) - https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL="App Name <noreply@yourdomain.com>"

# SMTP fallback (optional if not using Resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
